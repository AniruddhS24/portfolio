---
import { getConfigurationCollection } from "../../lib/utils";

const { data: config } = await getConfigurationCollection();
---

<div class="flex flex-col sm:flex-row items-center sm:items-end gap-8 sm:gap-14">
  <div class="profile-frame shrink-0">
    <img
      src="/profile.svg"
      alt="Profile sketch"
      class="profile-sketch"
    />
  </div>
  <div class="flex flex-col items-center sm:items-start gap-6">
    <h1
      class="text-3xl sm:text-4xl font-display font-semibold opsz text-center sm:text-left"
    >
      {config.hero.title}
    </h1>
    <h2
      class="text-center text-xl sm:text-2xl font-mono font-medium sm:text-left"
    >
      <p set:html={config.hero.subtitle}/>
    </h2>
  </div>
</div>

<style>
  .profile-frame {
    display: block;
    overflow: hidden;
    transition: background-color 0.15s ease-in-out;
  }

  .profile-sketch {
    display: block;
    width: 8rem;
    height: auto;
    object-fit: contain;
    /* Crop a sliver off the bottom of the photo */
    margin-bottom: -0.5rem;
    /* Force the sketch black in both modes (filter only affects the img, not the frame) */
    filter: brightness(0);
  }

  @media (min-width: 640px) {
    .profile-sketch {
      width: 10rem;
    }
  }

  /* Dark mode: sit the black sketch on a light frame instead of inverting it */
  :global(.dark) .profile-frame {
    background-color: var(--color-zag-light);
  }
</style>
